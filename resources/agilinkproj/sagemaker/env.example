# Copy to .env and fill in. NEVER commit the real .env (it's in .gitignore).
# Load it in the SageMaker shell with:  set -a; source .env; set +a

# Needed for gated models (e.g. google/gemma-3-4b-it).
# Create a read token at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where weights are downloaded. Point at a volume with >=120GB free
# (weights ~60GB + HF cache + datasets later). On SageMaker notebook instances,
# /home/ec2-user/SageMaker is persistent EBS -- size the volume accordingly.
MODEL_ROOT=/home/ec2-user/SageMaker/vlm-bench/models

# Optional: keep the HF cache off the small root disk too.
# HF_HOME=/home/ec2-user/SageMaker/hf-cache
